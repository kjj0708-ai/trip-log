rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isTripOwner(tripId) {
      // Use get() to check parent trip ownership for sub-collections
      return isSignedIn() && get(/databases/$(database)/documents/trips/$(tripId)).data.userId == request.auth.uid;
    }

    // --- Trips ---
    match /trips/{tripId} {
      function isValidTrip(data) {
        return data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 100 &&
               data.startDate is string &&
               data.endDate is string;
      }

      allow create: if isSignedIn() && isValidId(tripId) && isValidTrip(incoming());
      allow read: if isOwner(existing().userId);
      allow update: if isOwner(existing().userId) && isValidTrip(incoming()) &&
                      incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);

      // --- Sub-collections ---
      match /schedule/{itemId} {
        allow read: if isTripOwner(tripId);
        allow write: if isTripOwner(tripId);
      }

      match /journal/{entryId} {
        allow read: if isTripOwner(tripId);
        allow write: if isTripOwner(tripId);
      }

      match /expenses/{expenseId} {
        allow read: if isTripOwner(tripId);
        allow write: if isTripOwner(tripId);
      }

      match /checklist/{itemId} {
        allow read: if isTripOwner(tripId);
        allow write: if isTripOwner(tripId);
      }

      match /notes/{noteId} {
        allow read: if isTripOwner(tripId);
        allow write: if isTripOwner(tripId);
      }
    }
    
    // Test collection for initial connection validation
    match /test/connection {
      allow read: if true;
    }
  }
}
